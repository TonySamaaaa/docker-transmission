   tor = tr_torrentFindFromHash (handshake->session, hash);
   if (!memcmp (peer_id, tr_torrentGetPeerId(tor), PEER_ID_LEN))
     {
diff -ruN transmission-2.94/libtransmission/peer-mgr.c transmission-2.94-mod/libtransmission/peer-mgr.c
--- transmission-2.94/libtransmission/peer-mgr.c	2018-05-01 13:21:08.225549602 -0400
+++ transmission-2.94-mod/libtransmission/peer-mgr.c	2019-12-09 18:54:18.843658055 -0500
@@ -2016,7 +2016,7 @@
       if (io->utp_socket)
         atom->flags |= ADDED_F_UTP_FLAGS;
 
-      if (atom->flags2 & MYFLAG_BANNED)
+      if ((atom->flags2 & MYFLAG_BANNED) | tr_mod_client_banned(peer_id))
         {
           tordbg (s, "banned peer %s tried to reconnect",
                   tr_atomAddrStr (atom));
@@ -4082,3 +4082,16 @@
 
   tr_free (candidates);
 }
+
+bool
+tr_mod_client_banned (const uint8_t * peer_id)
+{
+  bool banned = false;
+  if (peer_id == NULL)
+    return banned;
+  banned |= !memcmp(peer_id+1, "SD", 2);
+  banned |= !memcmp(peer_id+1, "XL", 2);
+  if (banned)
+    tr_logAddNamedError ("Some client has been banned.", "(Client filter)");
+  return banned;
+}
