@@ -282,6 +282,9 @@
   handshake->havePeerID = true;
   dbgmsg (handshake, "peer-id is [%*.*s]", PEER_ID_LEN, PEER_ID_LEN, peer_id);
 
+  if (tr_mod_client_banned(peer_id))
